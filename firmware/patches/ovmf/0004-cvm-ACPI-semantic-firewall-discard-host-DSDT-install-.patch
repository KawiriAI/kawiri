@@ -0,0 +1,452 @@
+/** @file
+  CVM DSDT Reconstructor implementation.
+
+  Discards the host-provided DSDT/SSDT entirely and installs a
+  hardcoded, build-time-compiled DSDT from firmware. PCI MMIO
+  window values are patched in via magic sentinels at DXE time.
+
+  Copyright (c) 2025, Kawiri. All rights reserved.
+  SPDX-License-Identifier: BSD-2-Clause-Patent
+**/
+
+#include "CvmDsdtRecon.h"
+
+#include <IndustryStandard/Acpi.h>
+#include <IndustryStandard/UefiTcgPlatform.h>
+#include <Library/BaseLib.h>
+#include <Library/BaseMemoryLib.h>
+#include <Library/DebugLib.h>
+#include <Library/HobLib.h>
+#include <Library/MemoryAllocationLib.h>
+#include <Library/PcdLib.h>
+#include <Library/TpmMeasurementLib.h>
+#include <Pi/PiHob.h>
+
+//
+// The compiled DSDT AML blob, generated from CvmDsdt.asl at build time.
+//
+// Build pipeline (ovmf.nix postPatch):
+//   iasl -vw 6049 CvmDsdt.asl  ->  CvmDsdt.aml
+//   xxd -i CvmDsdt.aml         ->  CvmDsdtTemplate.h
+//
+// This produces: unsigned char CvmDsdt_aml[] and unsigned int CvmDsdt_aml_len
+//
+#include "CvmDsdtTemplate.h"
+
+//
+// Sentinel values -- must match CvmDsdt.asl
+//
+#define CVM_SENTINEL_MMIO32_BASE   0xCAFE0001UL
+#define CVM_SENTINEL_MMIO32_LIMIT  0xCAFE0002UL
+#define CVM_SENTINEL_MMIO32_SIZE   0xCAFE0003UL
+#define CVM_SENTINEL_MMIO64_BASE   0xCAFE000400000000ULL
+#define CVM_SENTINEL_MMIO64_LIMIT  0xCAFE000500000000ULL
+#define CVM_SENTINEL_MMIO64_SIZE   0xCAFE000600000000ULL
+
+//
+// MMIO isolation bounds
+//
+#define CVM_MAX_MMIO32_SIZE  SIZE_2GB
+#define CVM_MIN_MMIO64_BASE  0x100000000ULL
+
+/**
+  Search for a 4-byte sentinel in the AML blob and replace it.
+
+  Scans the entire AML blob for the first occurrence of the
+  little-endian sentinel value and replaces it with the given value.
+
+  @param[in,out] Aml       Pointer to mutable AML blob.
+  @param[in]     AmlSize   Size of AML blob in bytes.
+  @param[in]     Sentinel  The 4-byte sentinel (native endian).
+  @param[in]     Value     The replacement value (native endian).
+
+  @retval EFI_SUCCESS    Sentinel found and replaced.
+  @retval EFI_NOT_FOUND  Sentinel not found in AML.
+**/
+STATIC
+EFI_STATUS
+PatchDword (
+  IN OUT UINT8   *Aml,
+  IN     UINTN   AmlSize,
+  IN     UINT32  Sentinel,
+  IN     UINT32  Value
+  )
+{
+  UINTN  Offset;
+
+  for (Offset = 0; Offset + sizeof (UINT32) <= AmlSize; Offset++) {
+    if (CompareMem (&Aml[Offset], &Sentinel, sizeof (UINT32)) == 0) {
+      CopyMem (&Aml[Offset], &Value, sizeof (UINT32));
+      DEBUG ((
+        DEBUG_VERBOSE,
+        "CvmDsdt: patched DWord at 0x%x: 0x%08x -> 0x%08x\n",
+        Offset,
+        Sentinel,
+        Value
+        ));
+      return EFI_SUCCESS;
+    }
+  }
+
+  DEBUG ((DEBUG_ERROR, "CvmDsdt: DWord sentinel 0x%08x not found!\n", Sentinel));
+  return EFI_NOT_FOUND;
+}
+
+/**
+  Search for an 8-byte sentinel in the AML blob and replace it.
+
+  @param[in,out] Aml       Pointer to mutable AML blob.
+  @param[in]     AmlSize   Size of AML blob in bytes.
+  @param[in]     Sentinel  The 8-byte sentinel (native endian).
+  @param[in]     Value     The replacement value (native endian).
+
+  @retval EFI_SUCCESS    Sentinel found and replaced.
+  @retval EFI_NOT_FOUND  Sentinel not found in AML.
+**/
+STATIC
+EFI_STATUS
+PatchQword (
+  IN OUT UINT8   *Aml,
+  IN     UINTN   AmlSize,
+  IN     UINT64  Sentinel,
+  IN     UINT64  Value
+  )
+{
+  UINTN  Offset;
+
+  for (Offset = 0; Offset + sizeof (UINT64) <= AmlSize; Offset++) {
+    if (CompareMem (&Aml[Offset], &Sentinel, sizeof (UINT64)) == 0) {
+      CopyMem (&Aml[Offset], &Value, sizeof (UINT64));
+      DEBUG ((
+        DEBUG_VERBOSE,
+        "CvmDsdt: patched QWord at 0x%x: 0x%016Lx -> 0x%016Lx\n",
+        Offset,
+        Sentinel,
+        Value
+        ));
+      return EFI_SUCCESS;
+    }
+  }
+
+  DEBUG ((DEBUG_ERROR, "CvmDsdt: QWord sentinel 0x%016Lx not found!\n", Sentinel));
+  return EFI_NOT_FOUND;
+}
+
+//
+// OSDT ("Override System Description Table") is not defined in edk2 headers
+// but Linux/ACPICA loads AML from it (see acpi_tb_load_namespace in tbxfload.c).
+//
+#define CVM_ACPI_OSDT_SIGNATURE  SIGNATURE_32('O', 'S', 'D', 'T')
+
+BOOLEAN
+CvmIsAmlTable (
+  IN UINT32  Signature
+  )
+{
+  return (Signature == EFI_ACPI_1_0_DIFFERENTIATED_SYSTEM_DESCRIPTION_TABLE_SIGNATURE) ||
+         (Signature == EFI_ACPI_1_0_SECONDARY_SYSTEM_DESCRIPTION_TABLE_SIGNATURE) ||
+         (Signature == EFI_ACPI_1_0_PERSISTENT_SYSTEM_DESCRIPTION_TABLE_SIGNATURE) ||
+         (Signature == CVM_ACPI_OSDT_SIGNATURE);
+}
+
+EFI_STATUS
+EFIAPI
+CvmInstallReconstructedDsdt (
+  IN  EFI_ACPI_TABLE_PROTOCOL  *AcpiProtocol,
+  OUT UINTN                    *InstalledKey
+  )
+{
+  EFI_STATUS                  Status;
+  UINT8                       *DsdtCopy;
+  UINTN                       DsdtSize;
+  UINT64                      Mmio32Base;
+  UINT64                      Mmio32Size;
+  UINT64                      Mmio64Base;
+  UINT64                      Mmio64Size;
+  EFI_ACPI_DESCRIPTION_HEADER *Header;
+
+  DsdtSize = CvmDsdt_aml_len;
+  ASSERT (DsdtSize >= sizeof (EFI_ACPI_DESCRIPTION_HEADER));
+
+  //
+  // Step 1: Read PCI MMIO PCDs
+  //
+  Mmio32Base = PcdGet64 (PcdPciMmio32Base);
+  Mmio32Size = PcdGet64 (PcdPciMmio32Size);
+  Mmio64Base = PcdGet64 (PcdPciMmio64Base);
+  Mmio64Size = PcdGet64 (PcdPciMmio64Size);
+
+  DEBUG ((
+    DEBUG_INFO,
+    "CvmDsdt: MMIO32 base=0x%Lx size=0x%Lx\n",
+    Mmio32Base,
+    Mmio32Size
+    ));
+  DEBUG ((
+    DEBUG_INFO,
+    "CvmDsdt: MMIO64 base=0x%Lx size=0x%Lx\n",
+    Mmio64Base,
+    Mmio64Size
+    ));
+
+  //
+  // Step 2: Validate MMIO isolation invariants
+  //
+
+  // 32-bit window must exist
+  if ((Mmio32Base == 0) || (Mmio32Size == 0)) {
+    DEBUG ((DEBUG_ERROR, "CvmDsdt: FATAL - no 32-bit MMIO window\n"));
+    return EFI_SECURITY_VIOLATION;
+  }
+
+  // Check overflow
+  if (Mmio32Base + Mmio32Size < Mmio32Base) {
+    DEBUG ((DEBUG_ERROR, "CvmDsdt: FATAL - 32-bit MMIO overflow\n"));
+    return EFI_SECURITY_VIOLATION;
+  }
+
+  // Sanity bound
+  if (Mmio32Size > CVM_MAX_MMIO32_SIZE) {
+    DEBUG ((
+      DEBUG_ERROR,
+      "CvmDsdt: FATAL - 32-bit MMIO too large: 0x%Lx\n",
+      Mmio32Size
+      ));
+    return EFI_SECURITY_VIOLATION;
+  }
+
+  // Must fit in 32-bit DWordMemory descriptor — reject values above 4GiB
+  // to prevent silent truncation when patching AML sentinels.
+  if (Mmio32Base + Mmio32Size - 1 > MAX_UINT32) {
+    DEBUG ((
+      DEBUG_ERROR,
+      "CvmDsdt: FATAL - 32-bit MMIO exceeds 4GiB: base=0x%Lx size=0x%Lx\n",
+      Mmio32Base,
+      Mmio32Size
+      ));
+    return EFI_SECURITY_VIOLATION;
+  }
+
+  // 64-bit window: optional (no GPU = no 64-bit MMIO)
+  if (Mmio64Size > 0) {
+    if (Mmio64Base < CVM_MIN_MMIO64_BASE) {
+      DEBUG ((
+        DEBUG_ERROR,
+        "CvmDsdt: FATAL - 64-bit MMIO base below 4GiB: 0x%Lx\n",
+        Mmio64Base
+        ));
+      return EFI_SECURITY_VIOLATION;
+    }
+
+    if (Mmio64Base + Mmio64Size < Mmio64Base) {
+      DEBUG ((DEBUG_ERROR, "CvmDsdt: FATAL - 64-bit MMIO overflow\n"));
+      return EFI_SECURITY_VIOLATION;
+    }
+  }
+
+  //
+  // CRITICAL: Prove MMIO ∩ RAM = ∅ by checking resource HOBs.
+  //
+  // The MMIO PCDs are populated from QEMU's fw_cfg (etc/reserved-memory-end).
+  // A malicious host could set MMIO64 to overlap encrypted guest RAM.
+  // Resource HOBs are securely populated by the CPU TEE (TDX/SEV firmware),
+  // so they represent the ground truth for physical memory layout.
+  //
+  {
+    EFI_PEI_HOB_POINTERS  Hob;
+    UINT64                Mmio32End;
+    UINT64                Mmio64End;
+
+    Mmio32End = Mmio32Base + Mmio32Size;
+    Mmio64End = (Mmio64Size > 0) ? (Mmio64Base + Mmio64Size) : 0;
+
+    //
+    // Per-HOB interval overlap check for both MMIO windows.
+    // Each RAM region [RamStart, RamEnd) is tested against both
+    // MMIO32 and MMIO64 windows using standard interval overlap:
+    //   overlap iff (A.start < B.end) && (B.start < A.end)
+    //
+    Hob.Raw = GetFirstHob (EFI_HOB_TYPE_RESOURCE_DESCRIPTOR);
+    while (Hob.Raw != NULL) {
+      if (Hob.ResourceDescriptor->ResourceType == EFI_RESOURCE_SYSTEM_MEMORY) {
+        UINT64 RamStart = Hob.ResourceDescriptor->PhysicalStart;
+        UINT64 RamEnd   = RamStart + Hob.ResourceDescriptor->ResourceLength;
+
+        if ((Mmio32Size > 0) && (Mmio32Base < RamEnd) && (RamStart < Mmio32End)) {
+          DEBUG ((
+            DEBUG_ERROR,
+            "CvmDsdt: FATAL - MMIO32 [0x%Lx, 0x%Lx) overlaps RAM [0x%Lx, 0x%Lx)\n",
+            Mmio32Base,
+            Mmio32End,
+            RamStart,
+            RamEnd
+            ));
+          CpuDeadLoop ();
+        }
+
+        if ((Mmio64Size > 0) && (Mmio64Base < RamEnd) && (RamStart < Mmio64End)) {
+          DEBUG ((
+            DEBUG_ERROR,
+            "CvmDsdt: FATAL - MMIO64 [0x%Lx, 0x%Lx) overlaps RAM [0x%Lx, 0x%Lx)\n",
+            Mmio64Base,
+            Mmio64End,
+            RamStart,
+            RamEnd
+            ));
+          CpuDeadLoop ();
+        }
+      }
+      Hob.Raw = GetNextHob (EFI_HOB_TYPE_RESOURCE_DESCRIPTOR, GET_NEXT_HOB (Hob));
+    }
+  }
+
+  //
+  // Step 3: Make a mutable copy of the compiled DSDT template
+  //
+  DsdtCopy = AllocateCopyPool (DsdtSize, CvmDsdt_aml);
+  if (DsdtCopy == NULL) {
+    return EFI_OUT_OF_RESOURCES;
+  }
+
+  //
+  // Step 3a: Measure the DSDT template BEFORE patching sentinels
+  //
+  // By measuring the unpatched template (with sentinel placeholders),
+  // the RTMR value is identical regardless of PCI MMIO layout — meaning
+  // the same measurement whether the VM has 0, 1, or 8 GPUs.
+  //
+  // This is safe because:
+  //   - The measurement proves the correct DSDT template was installed
+  //   - The MMIO validation code (step 2) still runs and is itself
+  //     measured as part of MRTD (firmware code section)
+  //   - A malicious host cannot skip validation or change the template
+  //
+  // Same pattern as QEMU patch 0002 (static initrd address): measure
+  // a deterministic placeholder, then overwrite with the real value.
+  //
+  TpmMeasureAndLogData (
+    1,
+    EV_PLATFORM_CONFIG_FLAGS,
+    EV_POSTCODE_INFO_ACPI_DATA,
+    ACPI_DATA_LEN,
+    DsdtCopy,
+    DsdtSize
+    );
+
+  //
+  // Step 4: Patch 32-bit MMIO sentinels
+  //
+  Status = PatchDword (
+             DsdtCopy,
+             DsdtSize,
+             CVM_SENTINEL_MMIO32_BASE,
+             (UINT32)Mmio32Base
+             );
+  if (EFI_ERROR (Status)) {
+    goto FreeDsdt;
+  }
+
+  Status = PatchDword (
+             DsdtCopy,
+             DsdtSize,
+             CVM_SENTINEL_MMIO32_LIMIT,
+             (UINT32)(Mmio32Base + Mmio32Size - 1)
+             );
+  if (EFI_ERROR (Status)) {
+    goto FreeDsdt;
+  }
+
+  Status = PatchDword (
+             DsdtCopy,
+             DsdtSize,
+             CVM_SENTINEL_MMIO32_SIZE,
+             (UINT32)Mmio32Size
+             );
+  if (EFI_ERROR (Status)) {
+    goto FreeDsdt;
+  }
+
+  //
+  // Step 5: Patch 64-bit MMIO sentinels
+  //
+  // If no 64-bit window, zero out the sentinels (OS ignores zero-sized window).
+  //
+  Status = PatchQword (
+             DsdtCopy,
+             DsdtSize,
+             CVM_SENTINEL_MMIO64_BASE,
+             (Mmio64Size > 0) ? Mmio64Base : 0
+             );
+  if (EFI_ERROR (Status)) {
+    goto FreeDsdt;
+  }
+
+  Status = PatchQword (
+             DsdtCopy,
+             DsdtSize,
+             CVM_SENTINEL_MMIO64_LIMIT,
+             (Mmio64Size > 0) ? (Mmio64Base + Mmio64Size - 1) : 0
+             );
+  if (EFI_ERROR (Status)) {
+    goto FreeDsdt;
+  }
+
+  Status = PatchQword (
+             DsdtCopy,
+             DsdtSize,
+             CVM_SENTINEL_MMIO64_SIZE,
+             Mmio64Size
+             );
+  if (EFI_ERROR (Status)) {
+    goto FreeDsdt;
+  }
+
+  //
+  // Step 6: Fix DSDT header checksum (patching invalidated it)
+  //
+  Header = (EFI_ACPI_DESCRIPTION_HEADER *)DsdtCopy;
+  if (Header->Length != DsdtSize) {
+    DEBUG ((
+      DEBUG_ERROR,
+      "CvmDsdt: FATAL - template header Length (%u) != blob size (%u)\n",
+      Header->Length,
+      DsdtSize
+      ));
+    Status = EFI_COMPROMISED_DATA;
+    goto FreeDsdt;
+  }
+
+  Header->Checksum = 0;
+  Header->Checksum = CalculateCheckSum8 (DsdtCopy, Header->Length);
+
+  //
+  // Step 7: Install the patched DSDT
+  //
+  // InstallAcpiTable for DSDT automatically updates the FADT's
+  // DSDT and X_DSDT pointer fields.
+  //
+  Status = AcpiProtocol->InstallAcpiTable (
+                           AcpiProtocol,
+                           DsdtCopy,
+                           DsdtSize,
+                           InstalledKey
+                           );
+  if (EFI_ERROR (Status)) {
+    DEBUG ((
+      DEBUG_ERROR,
+      "CvmDsdt: InstallAcpiTable failed: %r\n",
+      Status
+      ));
+    goto FreeDsdt;
+  }
+
+  DEBUG ((
+    DEBUG_INFO,
+    "CvmDsdt: installed reconstructed DSDT (%u bytes)\n",
+    DsdtSize
+    ));
+
+FreeDsdt:
+  FreePool (DsdtCopy);
+  return Status;
+}
