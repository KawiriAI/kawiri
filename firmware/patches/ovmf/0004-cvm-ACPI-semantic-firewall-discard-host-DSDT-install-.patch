+/** @file
+  CVM Static DSDT for QEMU q35 machine type.
+
+  This DSDT is compiled at OVMF build time and installed by the
+  ACPI Semantic Firewall (CvmDsdtRecon.c). The host-provided DSDT
+  is discarded entirely — no host-generated AML is ever executed.
+
+  Runtime patching: magic sentinel values in _CRS are replaced with
+  actual PCI MMIO window addresses read from OVMF PCDs at DXE time.
+
+  The interrupt routing tables (PRTP/PRTA) replicate QEMU's
+  build_q35_routing_table() output exactly: 128 entries covering
+  slots 0x00-0x1F with 4 interrupt pins each.
+
+  Copyright (c) 2025, Kawiri. All rights reserved.
+  SPDX-License-Identifier: BSD-2-Clause-Patent
+**/
+
+DefinitionBlock ("CvmDsdt.aml", "DSDT", 2, "KAWIRI", "CVMDSDT", 0x00000001)
+{
+    //
+    // Interrupt model switch: PIC (0) / APIC (1)
+    //
+    Name (PICF, Zero)
+    Method (_PIC, 1, NotSerialized)
+    {
+        Store (Arg0, PICF)
+    }
+
+    //
+    // Sleep states — S5 only (no S3/S4 in CVM)
+    //
+    Name (\_S5, Package (0x04) { 0x00, 0x00, 0x00, 0x00 })
+
+    //
+    // Debug output to QEMU I/O port 0x0402
+    //
+    Method (DBUG, 1, NotSerialized)
+    {
+        OperationRegion (DBG0, SystemIO, 0x0402, One)
+        Field (DBG0, ByteAcc, NoLock, Preserve) { DBGB, 8 }
+        Store (Arg0, DBGB)
+    }
+
+    Scope (\_SB)
+    {
+        //
+        // ============================================================
+        // PCI Root Bridge (q35 / ICH9)
+        // ============================================================
+        //
+        Device (PCI0)
+        {
+            Name (_HID, EisaId ("PNP0A08"))  // PCIe root bridge
+            Name (_CID, EisaId ("PNP0A03"))  // PCI-compatible
+            Name (_ADR, Zero)
+            Name (_UID, Zero)
+
+            //
+            // _OSC: PCIe capability negotiation (trusted, minimal)
+            //
+            // Grants PME and AER (bits 2-4), denies hotplug (bits 0-1).
+            // Linux needs this to enable native PCIe error reporting.
+            //
+            // UUID: 33DB4D5B-1FF7-401C-9657-7441C03DD766 (PCIe Host Bridge)
+            //
+            Method (_OSC, 4, Serialized)
+            {
+                CreateDWordField (Arg3, 0x00, CDW1)
+                CreateDWordField (Arg3, 0x04, CDW2)
+                CreateDWordField (Arg3, 0x08, CDW3)
+
+                If (LEqual (Arg0, ToUUID ("33DB4D5B-1FF7-401C-9657-7441C03DD766")))
+                {
+                    // Mask off hotplug capabilities (bits 0-1), keep PME/AER/Cap (bits 2-4)
+                    And (CDW3, 0x1C, CDW3)
+
+                    If (LNotEqual (Arg1, One))
+                    {
+                        Or (CDW1, 0x08, CDW1)  // Unrecognized revision
+                    }
+                }
+                Else
+                {
+                    Or (CDW1, 0x04, CDW1)  // Unrecognized UUID
+                }
+
+                Return (Arg3)
+            }
+
+            //
+            // _CRS: PCI resource windows with sentinel patching
+            //
+            // Magic sentinels are replaced at runtime by CvmDsdtRecon.c:
+            //
+            //   DWord sentinels (32-bit MMIO):
+            //     0xCAFE0001 -> PcdPciMmio32Base
+            //     0xCAFE0002 -> PcdPciMmio32Base + PcdPciMmio32Size - 1
+            //     0xCAFE0003 -> PcdPciMmio32Size
+            //
+            //   QWord sentinels (64-bit MMIO):
+            //     0xCAFE000400000000 -> PcdPciMmio64Base
+            //     0xCAFE000500000000 -> PcdPciMmio64Base + PcdPciMmio64Size - 1
+            //     0xCAFE000600000000 -> PcdPciMmio64Size
+            //
+            Name (_CRS, ResourceTemplate ()
+            {
+                // Bus numbers: 0x00 - 0xFF
+                WordBusNumber (ResourceProducer, MinFixed, MaxFixed, PosDecode,
+                    0x0000, 0x0000, 0x00FF, 0x0000, 0x0100)
+
+                // I/O: PCI config mechanism
+                IO (Decode16, 0x0CF8, 0x0CF8, 0x01, 0x08)
+
+                // I/O: 0x0000 - 0x0CF7
+                WordIO (ResourceProducer, MinFixed, MaxFixed, PosDecode, EntireRange,
+                    0x0000, 0x0000, 0x0CF7, 0x0000, 0x0CF8)
+
+                // I/O: 0x0D00 - 0xFFFF
+                WordIO (ResourceProducer, MinFixed, MaxFixed, PosDecode, EntireRange,
+                    0x0000, 0x0D00, 0xFFFF, 0x0000, 0xF300)
+
+                // VGA memory: 0xA0000 - 0xBFFFF
+                DWordMemory (ResourceProducer, PosDecode, MinFixed, MaxFixed,
+                    Cacheable, ReadWrite,
+                    0x00000000, 0x000A0000, 0x000BFFFF, 0x00000000, 0x00020000)
+
+                // 32-bit PCI MMIO window — sentinels patched at runtime
+                DWordMemory (ResourceProducer, PosDecode, MinFixed, MaxFixed,
+                    NonCacheable, ReadWrite,
+                    0x00000000,
+                    0xCAFE0001,         // _MIN: sentinel -> PcdPciMmio32Base
+                    0xCAFE0002,         // _MAX: sentinel -> Mmio32Limit
+                    0x00000000,
+                    0xCAFE0003)         // _LEN: sentinel -> PcdPciMmio32Size
+
+                // 64-bit PCI MMIO window — sentinels patched at runtime
+                QWordMemory (ResourceProducer, PosDecode, MinFixed, MaxFixed,
+                    NonCacheable, ReadWrite,
+                    0x0000000000000000,
+                    0xCAFE000400000000, // _MIN: sentinel -> PcdPciMmio64Base
+                    0xCAFE000500000000, // _MAX: sentinel -> Mmio64Limit
+                    0x0000000000000000,
+                    0xCAFE000600000000) // _LEN: sentinel -> PcdPciMmio64Size
+            })
+
+            //
+            // _PRT: PCI interrupt routing tables (q35 layout)
+            //
+            // 128 entries: 32 slots x 4 interrupt pins.
+            // Generated from QEMU build_q35_routing_table() / append_q35_prt_entry().
+            //
+            // Slots 0x00-0x17: E + (slot & 3) rotation in EFGH group
+            // Slot 0x18: starts at E
+            // Slots 0x19-0x1D: starts at A (ICH9 internal devices)
+            // Slot 0x1E: starts at E (PCIe-to-PCI bridge)
+            // Slot 0x1F: starts at A (LPC/ISA bridge)
+            //
+
+            // PIC-mode routing: references \_SB.LNK{A-H} link devices
+            Name (PRTP, Package (128)
+            {
