+++ b/OvmfPkg/Library/AcpiPlatformLib/CvmDsdtRecon.h
@@ -0,0 +1,57 @@
+/** @file
+  CVM DSDT Reconstructor -- replaces host-provided DSDT/SSDT with
+  a hardcoded, measured, sentinel-patched DSDT.
+
+  Copyright (c) 2025, Kawiri. All rights reserved.
+  SPDX-License-Identifier: BSD-2-Clause-Patent
+**/
+
+#ifndef CVM_DSDT_RECON_H_
+#define CVM_DSDT_RECON_H_
+
+#include <Protocol/AcpiTable.h>
+#include <Uefi/UefiBaseType.h>
+
+/**
+  Check whether an ACPI table carries AML bytecode.
+
+  Returns TRUE for DSDT, SSDT, PSDT, and OSDT — all table types
+  from which Linux/ACPICA loads and executes AML.  A malicious host
+  could inject hostile AML via any of these signatures.
+
+  @param[in] Signature  The 4-byte ACPI table signature.
+
+  @retval TRUE   The signature is an AML-bearing table type.
+  @retval FALSE  Otherwise.
+**/
+BOOLEAN
+CvmIsAmlTable (
+  IN UINT32  Signature
+  );
+
+/**
+  Install the CVM hardcoded DSDT.
+
+  Reads PCI MMIO window PCDs, validates isolation invariants,
+  patches sentinel values in the compiled DSDT template,
+  measures the patched DSDT, and installs it via AcpiProtocol.
+
+  Must be called exactly once, after all host fw_cfg tables
+  have been processed.
+
+  @param[in]  AcpiProtocol   The ACPI table protocol.
+  @param[out] InstalledKey   Receives the installation key.
+
+  @retval EFI_SUCCESS            DSDT installed and measured.
+  @retval EFI_SECURITY_VIOLATION MMIO isolation check failed.
+  @retval EFI_NOT_FOUND          Sentinel not found in template.
+  @retval other                  Installation or measurement error.
+**/
+EFI_STATUS
+EFIAPI
+CvmInstallReconstructedDsdt (
+  IN  EFI_ACPI_TABLE_PROTOCOL  *AcpiProtocol,
+  OUT UINTN                    *InstalledKey
+  );
+
+#endif /* CVM_DSDT_RECON_H_ */
