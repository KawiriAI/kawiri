#!/bin/bash
# firewall-relax — open up the SSH-CVM's runtime firewall after boot.
#
# cvmbuild generates a strict per-image nftables ruleset from cvm.toml's
# [firewall] block: only declared inbound ports + established/related,
# and outbound deny except NTP. The platform's zero-trust check rejects
# `outbound = "allow"` at validate-time, so the only way to get a
# "developer-friendly default" out of an SSH-CVM image is to layer
# accept rules on top at boot. That's what this script does.
#
# Effects:
#   - Inbound: ICMP echo (so you can `ping` the VM from anywhere).
#   - Outbound: full accept (so the VM can reach the internet — apt
#     repos, GitHub, Docker pulls, etc).
#
# Reverting: just remove this service from cvm.toml in your fork and
# rebuild. The strict cvmbuild-generated ruleset stays.
#
# Idempotency: nftables `add rule` appends; running this script twice
# adds duplicates. Harmless (first match wins) but ugly, so we run as
# a oneshot with RemainAfterExit=yes.

set -euo pipefail

# Allow ICMP echo from anywhere. Pairs with the implicit
# `ct state established,related accept` already in the input chain so
# replies to outbound traffic also work.
nft add rule inet filter input ip protocol icmp accept

# Outbound: full accept. The chain already has rules for lo, established,
# and NTP — appending this terminal accept means anything else escapes
# the policy=drop too. cheaper than rewriting the whole chain.
nft add rule inet filter output accept

echo "firewall relaxed: icmp inbound + outbound any"
